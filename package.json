{
  "name": "env-guardian",
  "version": "1.0.0",
  "private": true,
  "description": ".env Guardian — local-first secret scanner & secure refactor engine",
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "install:all": "npm install --workspaces --include-workspace-root",
    "dev": "npm-run-all -p dev:server dev:client",
    "dev:server": "npm --prefix server run dev",
    "dev:client": "npm --prefix client run dev",
    "build": "npm-run-all -s build:server build:client",
    "build:server": "npm --prefix server run build",
    "build:client": "npm --prefix client run build",
    "typecheck": "npm-run-all -p typecheck:server typecheck:client",
    "typecheck:server": "npm --prefix server run typecheck",
    "typecheck:client": "npm --prefix client run typecheck",
    "start": "npm --prefix server run start"
  },
  "devDependencies": {
    "npm-run-all": "^4.1.5"
  }
}
