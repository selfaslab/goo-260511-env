{
  "name": "@env-guardian/server",
  "version": "1.0.0",
  "private": true,
  "description": ".env Guardian backend - secret scanning, AST tracing, risk engine, secure refactor",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
